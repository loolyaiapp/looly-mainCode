# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Razorpay (Indian payments) ───────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-secret-here
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# ── Lemon Squeezy (International payments) ───────────────────
# Get from: app.lemonsqueezy.com → Settings → Webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret-here

# ── Groq key pool (Pro AI proxy) ────────────────────────────
# Get free keys from: console.groq.com → API Keys (up to 6 accounts)
# Keys rotate round-robin; rate-limited keys skip to the next automatically
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3,gsk_key4,gsk_key5,gsk_key6

# ── Email (Gmail SMTP) ───────────────────────────────────────
# Use a Gmail account. Enable 2FA then create an App Password:
# myaccount.google.com → Security → App Passwords
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-gmail-app-password-here
EMAIL_FROM=Looly <youremail@gmail.com>
